# ============================================================
# Speech Recognition AI — Environment Configuration
# Copy this file to `.env` and fill in real values.
# Never commit your real .env file.
# ============================================================

# --- App ---
APP_NAME=speech-recognition-ai
APP_ENV=development              # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-string
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# --- Auth ---
JWT_SECRET_KEY=change-me-too
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Postgres ---
POSTGRES_USER=speechai
POSTGRES_PASSWORD=speechai_password
POSTGRES_DB=speechai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://speechai:speechai_password@postgres:5432/speechai

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- MinIO (S3-compatible object storage) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=speechai
MINIO_SECRET_KEY=speechai_secret_key
MINIO_BUCKET=speech-audio
MINIO_SECURE=false

# --- Vector store ---
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=voice_memories

# --- ASR engine ---
WHISPER_MODEL_SIZE=large-v3       # tiny | base | small | medium | large-v3
WHISPER_DEVICE=cpu                # cpu | cuda
WHISPER_COMPUTE_TYPE=int8         # int8 | float16 | float32
ASR_BACKEND=faster_whisper        # faster_whisper | whisper_cpp | hf_transformers

# --- Diarization ---
PYANNOTE_AUTH_TOKEN=               # required HuggingFace token for pyannote/speaker-diarization-3.1
DIARIZATION_DEVICE=cpu

# --- Speaker biometrics ---
SPEAKER_EMBEDDING_MODEL=speechbrain/spkrec-ecapa-voxceleb
SPEAKER_MATCH_THRESHOLD=0.75

# --- Emotion ---
EMOTION_MODEL=superb/wav2vec2-base-superb-er

# --- LLM Providers (plugin architecture, fill the ones you use) ---
LLM_PROVIDER=local                # openai | anthropic | gemini | local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
LOCAL_LLM_BASE_URL=http://ollama:11434
LOCAL_LLM_MODEL=llama3.1:8b

# --- Wake word ---
WAKE_WORD=hey aranya
WAKE_WORD_ENGINE=openwakeword      # openwakeword | porcupine

# --- Monitoring ---
PROMETHEUS_ENABLED=true
SENTRY_DSN=

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000/api/v1
